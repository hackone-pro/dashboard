# Etapa 1: build
FROM node:20 AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_API_URL
ARG VITE_API_BASE_URL
ARG VITE_CHAT_API_URL
ARG VITE_CUSTOMERS_API_URL
ARG VITE_TURNSTILE_SITE_KEY
ARG VITE_ENABLE_TURNSTILE
ARG VITE_ENABLE_INTEGRATIONS
ARG VITE_ENABLE_CONFIG
ARG VITE_WHATSAPP_SUPPORT

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_CHAT_API_URL=$VITE_CHAT_API_URL
ENV VITE_CUSTOMERS_API_URL=$VITE_CUSTOMERS_API_URL
ENV VITE_TURNSTILE_SITE_KEY=$VITE_TURNSTILE_SITE_KEY
ENV VITE_ENABLE_TURNSTILE=$VITE_ENABLE_TURNSTILE
ENV VITE_ENABLE_INTEGRATIONS=$VITE_ENABLE_INTEGRATIONS
ENV VITE_ENABLE_CONFIG=$VITE_ENABLE_CONFIG
ENV VITE_WHATSAPP_SUPPORT=$VITE_WHATSAPP_SUPPORT

RUN npm run build


# Etapa 2: runtime com nginx
FROM nginx:alpine

# Remove default config
RUN rm -rf /usr/share/nginx/html/*

# Copia build
COPY --from=builder /app/dist /usr/share/nginx/html

# Config SPA
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]